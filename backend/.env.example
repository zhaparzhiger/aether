# --- Server ---
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3002

# --- Database (docker-compose postgres+pgvector) ---
DATABASE_URL=postgresql://aether:aether@localhost:5433/aether
# Managed Postgres (Neon/Render) needs SSL. Leave unset locally; in production
# it defaults to on. Force with: DATABASE_SSL=true / DATABASE_SSL=false
# DATABASE_SSL=

# --- Auth (JWT) ---
# generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# --- File uploads ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=25

# --- Google Vertex AI (Gemini) ---
# Local dev: path to the service account key json file.
GOOGLE_APPLICATION_CREDENTIALS=../google-key.json
# Hosting (Render): instead of a file, paste the whole key json as one line here.
# When set, it is written to a temp file automatically at startup.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account", ...}
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- Google OAuth (login with Google) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- SMTP (team invite emails) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Aether <no-reply@aether.local>"
